        "ending": "ending_death",
        "summary": "你倒在了哨站的碎石与灰烬之间。"
      },
      "on_corruption_limit": {
        "ending": "ending_corrupt",
        "summary": "封匣里的低语彻底撬开了你的心智。"
      }
    },
    "resolve_victory": {
      "default": {
        "ending": "ending_victory",
        "summary": "你带着封匣离开了灰烬哨站。"
      },
      "rules": []
