  "endings": {
    "ending_victory": {
      "id": "ending_victory",
      "title": "封匣到手",
      "text": "你亲手击溃了哨站里的最后阻力，在碎石和余烬之间拖着封匣离开山脊。天亮之前，已经没有人能从你手里把它再夺回去。"
    },
    "ending_compromise": {
      "id": "ending_compromise",
      "title": "短暂的妥协",
      "text": "你没能彻底压住局势，却靠威胁、姿态和一点点退让逼对方停手。封匣仍被你带走，只是这笔账远远没有算完。"
    },
    "ending_delay": {
      "id": "ending_delay",
      "title": "拖延达标",
      "text": "你守住了最关键的几分钟，把封匣和局势一并拖进可控区间。胜利谈不上漂亮，却足够专业，也足够冷静。"
    },
    "ending_escape": {
      "id": "ending_escape",
      "title": "带着代价撤离",
      "text": "你放弃彻底压住哨站，带着封匣和未解的余波转身撤离。身后还有脚步、碎火和骂声，但至少任务没有烂在这里。"
    },
    "ending_death": {
      "id": "ending_death",
      "title": "哨站之下",
      "text": "你没能从灰烬与断墙之间再站起来。封匣、秘密，还有你没来得及带走的一切，都重新沉回了黑暗。"
    },
    "ending_corrupt": {
      "id": "ending_corrupt",
      "title": "低语入骨",
      "text": "封匣里的呢喃撬开了你最后一道防线。任务也许还算完成，但走下山脊的那个身影，已经不再是原来的你。"
    }
  },
  "nodes": {
    "mission_brief": {
      "title": "山脊上的简报",
      "text": "灰烬哨站伏在夜色里，像一头烧黑后仍未死透的兽。碎墙后面藏着你要取回的封匣，也藏着今晚会吞人的麻烦。你的任务很简单：进去，带出匣子，别让局势把你拖死在里面。{{doom_text}}",
      "actions": [
        {
          "id": "inspect_brief",
          "label": "借月光复核路线",
          "hint": "做一次基础侦察检定，争取额外准备和更稳的起手。",
          "kind": "check",
          "check": {
