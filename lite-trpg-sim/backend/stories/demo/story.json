  "world": {
    "id": "demo_world",
    "title": "Demo: 灰烬哨站的封匣",
    "chapter_title": "灰与风中的夜行夺匣",
    "tone": "tense-adventure",
    "intro": "灰烬哨站的烽灯已经熄了三夜。山脊上只剩断裂旗杆和半塌石墙，封存匣却还留在里面。你受命在天亮前潜入哨站，把匣子带回来，并在局势彻底恶化前决定这场夜行该如何收场。",
    "start_node": "mission_brief",
    "start_log": "你在山脊下接过了任务简报，夜风里夹着冷灰、潮湿石粉和旧铁锈的味道。",
    "default_shillings": 5,
    "corruption_limit": 10,
    "is_demo": true,
    "debug_trace_enabled": true,
    "debug_trace_limit": 500,
    "doom_texts": [
      {
        "min": 0,
        "text": "夜色仍在替你藏住脚步。"
      },
      {
        "min": 3,
        "text": "哨站深处的异响正在把这次任务推向失控。"
      }
    ],
    "corruption_penalties": [
      {
        "min": 4,
        "value": -1,
        "source": "腐化惩罚"
      }
    ],
    "default_ending_id": "ending_escape",
    "fatal_rules": {
